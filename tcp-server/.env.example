SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TCP_PORT=8080
UDP_PORT=8081
MAX_FRAME_BYTES=1400
UDP_ENDPOINT_TTL_MS=300000

# In-memory rate limits (DDoS / spam mitigation)
TCP_IP_CONN_LIMIT_PER_SEC=10
TCP_PAYLOAD_LIMIT_PER_MIN=50

# ChaCha20 timestamp skew window (seconds) for replay protection
TCP_REPLAY_SKEW_SEC=60

# 32-byte hex key — must match web NUXT_TCP_CREDENTIAL_KEY
TCP_CREDENTIAL_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
