{
  "name": "tcp-server",
  "version": "1.0.0",
  "description": "Struct binary TCP ingestion engine",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-parser.js && node test-parser-parity.js && node test-protocol.js && node test-crypto.js && node test-rateLimit.js && node test-replay.js && node test-webhooks.js && node test-udp.js",
    "test:parser": "node test-parser.js && node test-parser-parity.js",
    "build:native": "npm --prefix ./native-parser install && npm --prefix ./native-parser run build",
    "build:native:debug": "npm --prefix ./native-parser install && npm --prefix ./native-parser run build:debug"
  },
  "keywords": ["struct", "tcp", "iot", "binary"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
