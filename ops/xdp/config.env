# Struct XDP UDP prefilter configuration (Linux only).
# Sourced by load.sh / unload.sh.

# Network interface to attach XDP (required)
IFACE=eth0

# UDP destination port that Node listens on (must match TCP_SERVER UDP_PORT)
UDP_PORT=8081

# Maximum Protocol v2 datagram size admitted by XDP (outer UDP payload)
MAX_FRAME_BYTES=1400

# Object file produced by clang
OBJ=struct_ingress_kern.o

# Attach mode: skb (generic, works in most VMs) or native (driver XDP)
XDP_MODE=skb
